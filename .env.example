# Strapi Environment Variables
# Generate secure random strings for production
# You can generate using: openssl rand -base64 32

APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=toBeModified
ADMIN_JWT_SECRET=toBeModified
TRANSFER_TOKEN_SALT=toBeModified
JWT_SECRET=toBeModified

# Database Configuration (if using PostgreSQL or MySQL)
# Uncomment and configure if you want to use a different database
# DATABASE_CLIENT=postgres
# DATABASE_HOST=postgres
# DATABASE_PORT=5432
# DATABASE_NAME=strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi
# DATABASE_SSL=false

# Default is SQLite (no configuration needed)
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db
