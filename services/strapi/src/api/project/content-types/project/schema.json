{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Projeto",
    "description": "Projetos do portfólio"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "icon": {
      "type": "string",
      "required": true,
      "default": "pi pi-code"
    },
    "technologies": {
      "type": "json",
      "required": true
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
